certirocq_vanilla_plugin.cmxa: certirocq_vanilla_plugin.cmx ../../runtime/lib/get_ordinal.o
	$(HIDE)$(TIMER) $(CAMLOPTLINK) ../../runtime/lib/get_ordinal.o $(CAMLDEBUG) $(CAMLFLAGS) $(FINDLIBPKGS) -a -o $@ $<

g_certirocq_vanilla.ml: g_certirocq_vanilla.mlg ../common/certirocq_commands.mlg
	$(SHOW)'CPP+COQPP $<'
	$(HIDE)tmp=$$(mktemp /tmp/g_certirocq_vanilla.XXXXXX.mlg); \
		cpp -traditional-cpp -P $< > $$tmp; \
		$(COQPP) $$tmp; \
		mv $${tmp%.mlg}.ml $@; \
		rm -f $$tmp
