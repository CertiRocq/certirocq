COQOPTS = -R ../../plugin CertiRocq.Plugin -I ../../plugin -R ../lib CertiRocq.Tests.lib

# Benchmarks compiled and run by this directory.
TESTS=$(shell cat TESTS)

# Benchmarks regenerated by tests.v.
EXTRACTED_MODULES=$(TESTS)
EXTRACTED_MLFILES=$(patsubst %,%.ml, $(EXTRACTED_MODULES))
EXTRACTED_MLIFILES=$(patsubst %,%.mli, $(EXTRACTED_MODULES))
CMOFILES=$(patsubst %,%.cmo, $(TESTS))
CMXFILES=$(patsubst %,%.cmx, $(TESTS))

default: run
all: run

.PHONY: tests run clean cleanml

exec: main mainopt

$(EXTRACTED_MLFILES) $(EXTRACTED_MLIFILES): tests

clean: cleanml
	rm -f ./*.cmi
	rm -f ./*.cmo
	rm -f ./*.cmx
	rm -f ./*.cma
	rm -f ./*.o
	rm -f main mainopt
	rm -f ./*.glob ./*.vo ./*.vos ./*.vok

cleanml :
	rm -f $(EXTRACTED_MLFILES) $(EXTRACTED_MLIFILES)
	rm -f color.ml color.mli sha.ml sha.mli


$(CMOFILES): %.cmo: %.ml %.mli
	ocamlc -c $*.mli
	ocamlc -c $*.ml

$(CMXFILES): %.cmx: %.ml %.mli
	ocamlopt -c $*.mli
	ocamlopt -c $*.ml

main.cmo: main.ml $(CMOFILES)
	ocamlc -c $<

main.cmx: main.ml $(CMXFILES)
	ocamlopt -c $<

main: $(CMOFILES) main.cmo
	ocamlc -o main unix.cma $(CMOFILES) main.cmo 

mainopt: $(CMXFILES) main.cmx
	ocamlopt -o mainopt unix.cmxa $(CMXFILES) main.cmx

tests: tests.v
	rocq c $(COQOPTS) tests.v

run: main mainopt
	./main 10
	./mainopt 10
